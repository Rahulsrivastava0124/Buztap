{
  "name": "staff-attendance-app",
  "version": "1.0.0",
  "description": "React Native Expo app for staff attendance tracking",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start --go --lan",
    "start:tunnel": "expo start --go --tunnel",
    "dev": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "eas build",
    "build:ios": "eas build --platform ios --profile production-ios",
    "build:ios:preview": "eas build --platform ios --profile preview-ios",
    "build:ios:simulator": "eas build --platform ios --profile development-ios-simulator",
    "submit": "eas submit"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/stack": "^6.3.20",
    "axios": "^1.6.5",
    "date-fns": "^2.30.0",
    "expo": "^54.0.34",
    "expo-application": "~7.0.8",
    "expo-dev-client": "~6.0.21",
    "expo-font": "~14.0.11",
    "expo-navigation-bar": "~5.0.10",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-toast-notifications": "^3.4.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "zustand": "^4.4.1"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@types/react": "~19.1.10",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.3.0"
  },
  "private": true,
  "expo": {
    "name": "Staff Attendance",
    "slug": "staff-attendance",
    "version": "1.0.0",
    "scheme": "staffattendance",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "android": {
      "package": "com.tableqr.staffattendance",
      "versionCode": 1
    },
    "ios": {
      "bundleIdentifier": "com.tableqr.staffattendance"
    }
  }
}
