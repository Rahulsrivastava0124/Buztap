{
  "expo": {
    "name": "Staff Attendance",
    "slug": "staff-attendance",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/designarena_image_eewduh3n.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/designarena_image_eewduh3n.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tableqr.staffattendance",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/designarena_image_eewduh3n.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.tableqr.staffattendance",
      "permissions": ["CAMERA", "INTERNET"]
    },
    "web": {
      "favicon": "./assets/designarena_image_eewduh3n.png"
    },
    "scheme": "staffattendance",
    "plugins": ["expo-font", "expo-secure-store"],
    "extra": {
      "eas": {
        "projectId": "c4b911f9-02ca-4940-ad1d-d4365db48bcc"
      }
    }
  }
}
