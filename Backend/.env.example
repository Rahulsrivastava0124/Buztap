# Environment variables — copy to .env and fill in values

PORT=5000
MONGO_URI=mongodb://localhost:27017/tableqr
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Guest menu URL generation
# Local fallback when APP_BASE_DOMAIN is not set
MENU_APP_BASE_URL=http://localhost:5174
# Production domain for auto subdomain links (example: APP_BASE_DOMAIN=buztap.com)
APP_BASE_DOMAIN=

