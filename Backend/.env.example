# Environment variables — copy to .env and fill in values

PORT=5000

# Local development (no Docker):
MONGO_URI=mongodb://localhost:27017/tableqr
# Docker / docker-compose — use the service name "mongo" instead of localhost:
# MONGO_URI=mongodb://mongo:27017/tableqr

JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Guest menu URL generation
# Local fallback when APP_BASE_DOMAIN is not set
MENU_APP_BASE_URL=http://localhost:5173
# Public customer-facing menu app base (used in production QR links)
PUBLIC_MENU_BASE_URL=https://buztap.com
# Production domain for auto subdomain links (example: APP_BASE_DOMAIN=buztap.com)
APP_BASE_DOMAIN=

# Cloudflare R2 Storage (leave blank to disable image uploads)
R2_ACCOUNT_ID=your_r2_account_id
R2_BUCKET_NAME=your_r2_bucket_name
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_PUBLIC_URL=https://your-bucket.r2.dev

# Email OTP (GoDaddy SMTP by default)
MAIL_PROVIDER=godaddy
MAIL_HOST=smtpout.secureserver.net
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=info@buztap.com
MAIL_PASS=Buztap@2026
MAIL_FROM=info@buztap.com
MAIL_SENDER_NAME=BuzTap OTP
